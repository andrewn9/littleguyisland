void vertex() {
	for (int i = 0; i < waves.length(); i++) {
		Wave wave = waves[i];
		VERTEX.y += wave_strength * wave.amplitude * 0.5f * (0.5f + sin(PI * (time_scale * TIME + wave.offset + wave.frequency * (wave.direction.x * VERTEX.x + wave.direction.y * VERTEX.z))));
	}
}

void fragment() {
	vec3 world_pos = (INV_VIEW_MATRIX * vec4(VERTEX, 1.0f)).xyz;
	
	vec2 deriv = vec2(0.0f);
	for (int i = 0; i < waves.length(); i++) {
		Wave wave = waves[i];
		deriv += wave_strength * wave.direction * wave.amplitude * PI * wave.frequency * cos(PI * (time_scale * TIME + wave.offset + wave.frequency * (wave.direction.x * world_pos.x + wave.direction.y * world_pos.z)));
	}
	
	// deriv /= float(waves.length());

	deriv *= normal_strength;
	
	//NORMAL_MAP = normalize(cross(normalize(vec3(1.0f, 0.0f, deriv.x)), normalize(vec3(0.0f, 1.0f, deriv.y))));
	NORMAL_MAP = normalize(vec3(deriv.x, deriv.y, 1.0f));
	NORMAL_MAP = NORMAL_MAP * 0.5f + 0.5f;
	
	ROUGHNESS = roughness;
	SPECULAR = specular;
	
	ALBEDO = color;
}